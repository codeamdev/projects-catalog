# ── Base de datos ─────────────────────────────────────────────────
# Cadena de conexión a PostgreSQL.
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base
DATABASE_URL="postgresql://postgres:password@localhost:5432/project_catalogo"

# ── NextAuth ───────────────────────────────────────────────────────
# URL base de la aplicación (sin trailing slash).
# En desarrollo usa el subdominio de cualquier tenant (NextAuth lo necesita para callbacks).
NEXTAUTH_URL="http://perfumeria.allexclusive.com:3000"

# Secreto criptográfico para firmar y cifrar los JWT de sesión.
# IMPORTANTE: en producción este valor DEBE ser único, largo y aleatorio.
# Generarlo con: openssl rand -base64 32
# Nunca reutilizar el mismo secreto entre entornos (dev / staging / prod).
NEXTAUTH_SECRET="REEMPLAZAR_CON_VALOR_DE_openssl_rand_-base64_32"

# ── Dominio raíz ──────────────────────────────────────────────────
# Dominio sobre el que corren los subdominios de los tenants.
# Ej: "allexclusive.com" → tenants en *.allexclusive.com
# En desarrollo local: "allexclusive.com" (con entradas en /etc/hosts)
NEXT_PUBLIC_ROOT_DOMAIN="allexclusive.com"
