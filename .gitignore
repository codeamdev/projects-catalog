# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencias ──────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Variables de entorno (nunca al repo) ─────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
# .env.example sí se sube (es la plantilla sin valores reales)

# ── Uploads de usuarios (se almacenan en el servidor, no en el repo)
/public/uploads/

# ── Logs ──────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Backups de base de datos ──────────────────────────────────────
*.sql.gz
*.dump

# ── Sistema operativo ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Certificados y claves ─────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ── TypeScript ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ───────────────────────────────────────────────────────
/coverage

# ── Vercel ────────────────────────────────────────────────────────
.vercel

# ── IDE y editores ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Archivos de debug y temporales ───────────────────────────────
.cache/
tmp/
temp/

# ── Prisma generado (no se usa, pero por si acaso) ────────────────
/src/generated/prisma

# ── Credenciales locales ──────────────────────────────────────────
CREDENCIALES.md
